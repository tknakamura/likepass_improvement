NODE_ENV=development
APP_URL=http://localhost:3000

DATABASE_URL=postgresql://likepass:likepass@localhost:5432/likepass

AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TRUST_HOST=true
# Required on Render so OAuth callbacks use the public URL, not 0.0.0.0
# Set to https://likepass-web.onrender.com (or your custom domain)
AUTH_URL=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

IMAGE_AI_PROVIDER=mock
IMAGE_AI_API_KEY=
# gpt-4o recommended for tagging accuracy; gpt-4o-mini is cheaper
IMAGE_AI_MODEL=gpt-4o

SENTRY_DSN=
NEXT_PUBLIC_ANALYTICS_KEY=

ADMIN_EMAIL_ALLOWLIST=

# Demo mode: one-click login + seeded sample photos (dev/preview only)
DEMO_MODE=false
